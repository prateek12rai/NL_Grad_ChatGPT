# Copy to .env and fill in values (never commit .env)

# Groq — LLM answers (Phase 5) — https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_MOCK=false
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.1
RAG_TOP_K=8
RAG_MAX_DISTANCE=0.85
# Local dev + Vercel (add your *.vercel.app URLs on Render — see docs/deployment-plan.md)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:3000

# Hugging Face — embeddings BAAI/bge-large-en-v1.5 (Phase 4)
HUGGINGFACE_API_TOKEN=
EMBED_MODEL_ID=BAAI/bge-large-en-v1.5
EMBED_BATCH_SIZE=16
EMBED_MOCK=false
RAG_CONTEXT_CHUNKS=5
RAG_TEMPERATURE=0.35
RAG_NATURE_LIVE_COUNT=false

# Local paths
CHROMA_PATH=./chroma_db
CHUNK_OUTPUT_DIR=./data/chunks
CHUNK_INDEX_PATH=./data/chunks/index.json
CORPUS_PATH=./data/corpus
MAX_DOCUMENTS=20

# Nature-only ingest (single listing URL — last 30 days, keep 20 newest)
NATURE_SEARCH_URL=https://www.nature.com/search?article_type=research&subject=medical-research&date_range=last_30_days&order=relevance
SCRAPER_NATURE_MAX_PAGES=2
SCRAPER_NATURE_MAX_ARTICLES=20
SCRAPER_MAX_PER_SOURCE=20
SCRAPER_MAX_TOTAL=20
SCRAPER_REQUEST_DELAY_SECONDS=1.0
SCRAPER_MAX_PDF_MB=12

# Frontend (Vercel): set VITE_BACKEND_URL in Vercel — see frontend/.env.example
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
